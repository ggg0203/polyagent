# PolyAgent configuration — copy this file to `.env` and fill in your values.
# `.env` is gitignored; never commit real keys.

# --- DeepSeek (specific) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Generic OpenAI-compatible (阿里百炼 / 通义千问 / 百川 / etc.) ---
# Uncomment and fill these to use OpenAICompatibleProvider.
# LLM_API_KEY=sk-your-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-max

# Observability (optional — leave blank to keep in-memory)
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PUSHGATEWAY=
